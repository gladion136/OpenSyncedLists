<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.OpenSyncedLists" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <!-- White, so toolbar title/icons stay visible on the black bar. -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_700</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:navigationBarColor">@android:color/transparent
        </item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">
            ?attr/colorPrimaryVariant
        </item>
        <item name="toolbarStyle">@style/MyToolbarStyle</item>
        <!-- Explicit dialog theme, shared with the light theme. -->
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="materialAlertDialogTheme">@style/AppAlertDialogTheme</item>
    </style>
</resources>