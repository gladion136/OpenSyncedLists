<resources>
    <!-- Base application theme. -->

    <style name="Theme.OpenSyncedLists" parent="Theme.MaterialComponents.Light">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:navigationBarColor">@android:color/transparent
        </item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">
            ?attr/colorPrimaryVariant
        </item>
        <!-- Customize your theme here. -->
        <item name="toolbarStyle">@style/MyToolbarStyle</item>
        <!-- Explicit dialog theme so button text colors are deterministic and
             do not depend on the OEM default (Samsung/Xiaomi differ). -->
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="materialAlertDialogTheme">@style/AppAlertDialogTheme</item>
    </style>

    <style name="MyToolbarStyle" parent="Widget.MaterialComponents.Toolbar">
        <item name="titleTextColor">?attr/colorOnPrimary</item>
        <item name="subtitleTextColor">?attr/colorOnPrimary</item>
        <item name="android:theme">@style/ToolbarIconsTheme
        </item> <!-- sets icon tint -->
    </style>

    <style name="ToolbarIconsTheme" parent="">
        <item name="colorControlNormal">?attr/colorOnPrimary</item>
    </style>

    <!-- Shared dialog theme. The DayNight parent resolves the correct
         background/text colors per mode; buttons use the primary color so they
         stay clearly visible on every device. -->
    <style name="AppAlertDialogTheme"
        parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="buttonBarPositiveButtonStyle">@style/AppAlertDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/AppAlertDialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/AppAlertDialogButton</item>
    </style>

    <style name="AppAlertDialogButton"
        parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <!-- textColorPrimary follows the theme (dark text on light, light text
             on dark), guaranteeing contrast against the dialog surface on every
             device. -->
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>


</resources>